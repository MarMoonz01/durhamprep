# Google Sheets Configuration
# 1. Create a Google Sheet with these tab names: accom, vaccines, packing, shopping, introvert
# 2. Share the sheet: Share → Anyone with the link → Viewer
# 3. Copy the Spreadsheet ID from the URL:
#    https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# 4. Copy this file to .env and fill in the ID below

VITE_GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# NO API KEY REQUIRED — uses the public CSV export URL directly.
#
# Column layouts for each tab are documented in src/services/googleSheets.js
# If .env is not set, the app uses built-in default data from src/data/defaults.js
